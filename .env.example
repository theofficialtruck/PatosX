# ─────────────────────────────────────────────────────────────────────────────
# DuckParadise Bot — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# MongoDB connection URI (from https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=DuckParadise

# OpenRouter API key for AI fallback (from https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Tenor GIF API key (from https://tenor.com/developer/dashboard)
TENOR_API_KEY=your_tenor_api_key_here

# Quote API key (from https://api-ninjas.com or similar)
QUOTE_API_KEY=your_quote_api_key_here

# Comma-separated list of Google Gemini API keys for DuckGPT
# Rotate through multiple keys to avoid rate limits
# Get keys from https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2

# Set to "true" to enable verbose debug output on startup (default: false)
DUCKPARADISE_DEBUG_COMMANDS=false

# Comma-separated list of Discord user IDs that are treated as bot owners/admins
# These users can bypass staff-role checks and use privileged commands (addmoney, override, etc.)
AUTHORIZED_USER_IDS=your_discord_user_id_here,other_admin_id_here

# Comma-separated list of usernames that appear as donors in the /beg command
# Change these to any display names you want shown to users who run /beg
BEG_DONORS=thetruck,theofficialtruck
